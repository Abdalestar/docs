{
  "deployUrl": "https://dashboard.qtap.qa",
  "section": "merchants/points",
  "account": "points",
  "defaultWaitMs": 3000,
  "viewport": { "width": 1440, "height": 1300 },
  "steps": [
    {
      "name": "points-edit-01-menu",
      "goto": "/points",
      "waitFor": "text=Points Programs",
      "waitMs": 5500,
      "actions": [
        { "click": "button:has(svg.lucide-ellipsis)" },
        { "wait": 900 }
      ],
      "annotate": [
        { "type": "box", "target": "[role=menuitem]:has-text('Edit')", "number": 1, "color": "plum" },
        { "type": "label", "target": "[role=menuitem]:has-text('Edit')", "text": "Choose Edit, or click the card itself", "color": "plum" },
        { "type": "caption", "text": "On the Points page, open the menu on a program and choose Edit. Clicking the card preview opens the same editor." }
      ]
    },
    {
      "name": "points-edit-02-form",
      "actions": [
        { "click": "[role=menuitem]:has-text('Edit')" },
        { "wait": 4000 }
      ],
      "waitFor": "text=Edit Points Program",
      "waitMs": 2000,
      "annotate": [
        { "type": "box", "target": "h1:has-text('Edit Points Program')", "number": 1, "color": "plum" },
        { "type": "box", "target": "div.hidden.lg\\:block.w-80", "color": "charcoal" },
        { "type": "label", "target": "div.hidden.lg\\:block.w-80", "text": "The live preview updates as you edit", "color": "charcoal" },
        { "type": "caption", "text": "The editor opens with every setting filled in from the current program. Change anything: the name, points per currency, color, rewards, expiry, or locations." }
      ]
    },
    {
      "name": "points-edit-03-rewards",
      "actions": [
        { "wait": 600 }
      ],
      "clipTo": "div.rounded-xl:has(div:has-text('What can customers redeem points for?'))",
      "clipPadding": 12
    },
    {
      "name": "points-edit-04-save",
      "actions": [
        { "hover": "button:has-text('Save & Activate')" },
        { "wait": 600 }
      ],
      "clipTo": "div.flex.justify-end.gap-4",
      "clipPadding": 22,
      "annotate": [
        { "type": "box", "target": "button:has-text('Save as Draft')", "number": 1, "color": "charcoal" },
        { "type": "box", "target": "button:has-text('Save & Activate')", "number": 2, "color": "plum" }
      ]
    }
  ]
}
