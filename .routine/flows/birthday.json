{
  "deployUrl": "https://dashboard.qtap.qa",
  "section": "campaigns",
  "account": "stamp",
  "viewport": { "width": 1440, "height": 1000 },
  "defaultWaitMs": 2500,
  "steps": [
    {
      "name": "birthday-01-type",
      "goto": "/campaigns/new",
      "actions": [
        { "wait": 4000 },
        { "click": "label:has-text('Birthday Rewards')" },
        { "fill": ["#name", "Birthday Bonus"] },
        { "wait": 700 }
      ],
      "waitFor": "text=Choose Campaign Type",
      "waitMs": 1500,
      "annotate": [
        { "type": "box", "target": "label:has-text('Birthday Rewards')", "number": 1, "color": "plum" },
        { "type": "box", "target": "#name", "number": 2, "color": "plum" },
        { "type": "caption", "text": "Step 1, Type: choose Birthday Rewards (1) and give the campaign a name (2), then click Next." }
      ]
    },
    {
      "name": "birthday-02-trigger",
      "actions": [
        { "click": "button:has-text('Next')" },
        { "wait": 1500 }
      ],
      "waitFor": "text=before birthday",
      "waitMs": 1000,
      "annotate": [
        { "type": "box", "target": "button[role=combobox]", "number": 1, "color": "plum" },
        { "type": "caption", "text": "Step 2, Trigger: choose when the birthday reward sends, on the day or 1, 3, or 7 days before. The default is 3 days before." }
      ]
    },
    {
      "name": "birthday-03-message",
      "goto": "/campaigns/new",
      "actions": [
        { "wait": 4000 },
        { "click": "label:has-text('Birthday Rewards')" },
        { "fill": ["#name", "Birthday Bonus"] },
        { "wait": 600 },
        { "click": "button:has-text('Next')" },
        { "wait": 1500 },
        { "click": "button:has-text('Next')" },
        { "wait": 1500 },
        { "click": "button:has-text('Next')" },
        { "wait": 1200 },
        { "fill": ["#notification-title", "Happy Birthday!"] },
        { "fill": ["#notification-body", "Your birthday treat is waiting. Drop by this week and it's on us."] },
        { "wait": 700 }
      ],
      "waitFor": "text=Customize Message",
      "waitMs": 1000,
      "annotate": [
        { "type": "box", "target": "#notification-title", "number": 1, "color": "plum" },
        { "type": "box", "target": "#notification-body", "number": 2, "color": "plum" },
        { "type": "caption", "text": "Step 4, Message: write the Notification Title (1) and Message (2). Keep the body short so it does not truncate on phones." }
      ]
    },
    {
      "name": "birthday-04-review",
      "goto": "/campaigns/new",
      "actions": [
        { "wait": 4000 },
        { "click": "label:has-text('Birthday Rewards')" },
        { "fill": ["#name", "Birthday Bonus"] },
        { "wait": 600 },
        { "click": "button:has-text('Next')" },
        { "wait": 1400 },
        { "click": "button:has-text('Next')" },
        { "wait": 1400 },
        { "click": "button:has-text('Next')" },
        { "wait": 1200 },
        { "fill": ["#notification-title", "Happy Birthday!"] },
        { "fill": ["#notification-body", "Your birthday treat is waiting. Drop by this week and it's on us."] },
        { "wait": 600 },
        { "click": "button:has-text('Next')" },
        { "wait": 1300 },
        { "click": "button:has-text('Next')" },
        { "wait": 1300 },
        { "click": "button:has-text('Next')" },
        { "wait": 1500 }
      ],
      "waitFor": "button:has-text('Activate Campaign')",
      "waitMs": 1200,
      "annotate": [
        { "type": "box", "target": "button:has-text('Activate Campaign')", "number": 1, "color": "plum" },
        { "type": "box", "target": "button:has-text('Save as Draft')", "number": 2, "color": "gold" },
        { "type": "caption", "text": "Step 7, Review: check the summary, then Activate Campaign (1) to start it, or Save as Draft (2) to publish later." }
      ]
    }
  ]
}
