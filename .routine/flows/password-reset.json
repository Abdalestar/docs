{
  "account": "points",
  "section": "settings",
  "viewport": { "width": 1440, "height": 900 },
  "steps": [
    {
      "name": "password-reset-forgot",
      "goto": "/forgot-password",
      "waitFor": "text=Forgot Password",
      "waitMs": 1500,
      "actions": [
        { "fill": ["#email", "owner@yourcafe.com"] },
        { "wait": 400 }
      ],
      "clipTo": ".shadow-lg",
      "clipPadding": 18,
      "annotate": [
        { "type": "box", "target": "#email", "number": 1 },
        { "type": "box", "target": "button:has-text('Send Reset Link')", "number": 2 }
      ]
    },
    {
      "name": "password-reset-new",
      "goto": "/reset-password",
      "waitFor": "text=Reset Password",
      "waitMs": 1500,
      "clipTo": ".shadow-lg",
      "clipPadding": 18,
      "annotate": [
        { "type": "box", "target": "#password", "number": 1 },
        { "type": "box", "target": "#confirmPassword", "number": 2 },
        { "type": "box", "target": "button:has-text('Reset Password')", "number": 3 }
      ]
    }
  ]
}
