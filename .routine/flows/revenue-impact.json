{
  "deployUrl": "https://dashboard.qtap.qa",
  "section": "analytics",
  "account": "points",
  "defaultWaitMs": 3000,
  "viewport": { "width": 1440, "height": 900 },
  "steps": [
    {
      "name": "revenue-impact-overview",
      "goto": "/analytics/reports/revenue-impact",
      "waitFor": "text=Revenue Impact Report",
      "waitMs": 6500,
      "annotate": [
        { "type": "box", "target": "div:has(> p:text-is('Total Revenue'))", "number": 1, "color": "plum" },
        { "type": "box", "target": "div:has(> p:text-is('Loyalty Transactions'))", "number": 2, "color": "plum" },
        { "type": "box", "target": "div:has(> p:text-is('Avg Revenue / Transaction'))", "number": 3, "color": "plum" },
        { "type": "caption", "text": "The Revenue Impact Report. Three figures summarise the period: (1) Total Revenue, (2) Loyalty Transactions, (3) Average Revenue per Transaction." }
      ]
    },
    {
      "name": "revenue-impact-filters",
      "goto": "/analytics/reports/revenue-impact",
      "waitFor": "text=Revenue Impact Report",
      "waitMs": 6000,
      "clip": { "x": 0, "y": 0, "width": 1440, "height": 240 },
      "annotate": [
        { "type": "box", "target": "text=All branches", "color": "plum" },
        { "type": "box", "target": "text=Last 30 days", "color": "plum" },
        { "type": "label", "target": "text=Last 30 days", "text": "Change branch or time period and the report reloads.", "color": "charcoal" }
      ]
    },
    {
      "name": "revenue-impact-chart",
      "goto": "/analytics/reports/revenue-impact",
      "waitFor": "text=Revenue & Loyalty Activity Over Time",
      "actions": [
        { "hover": "div.rounded-xl:has(.recharts-wrapper)" },
        { "wait": 1500 }
      ],
      "waitMs": 4000,
      "clipTo": "div.rounded-xl:has(.recharts-wrapper)",
      "clipPadding": 12
    }
  ]
}
